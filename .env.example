GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-3.0-flash

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=YOUR_NEO4J_PASSWORD

EMBED_MODEL=jhgan/ko-sroberta-multitask
PDF_DIR=C:\\path\\to\\neo4j\\pdf

# Retrieval tuning
TOP_CAT=4
TOP_SUB=8
TOP_CHUNK=36
FINAL_TOP=10
VEC_WEIGHT=0.62
KW_WEIGHT=0.38
LEXICAL_CAND_LIMIT=500

# Answering thresholds
MIN_CHUNKS_FOR_ANSWER=2
MIN_BEST_SCORE=0.40
SEM_DEDUP_THRESHOLD=0.95
MMR_LAMBDA=0.80

# Optional reranking
ENABLE_LLM_RERANK=0
LLM_RERANK_CAND=12

# Crawl is disabled in code by default
CRAWL_MAX_DOCS=8
CRAWL_SEARCH_TIMEOUT=5
CRAWL_FETCH_TIMEOUT=6
CRAWL_SLEEP_SEC=0.15

# Student agent settings
TOP_K=6
HISTORY_TURNS=3
MIN_SCORE=0.25
